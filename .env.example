# Core backend configuration
DATABASE_URL=postgresql://postgres:your_secure_password_here@localhost:5432/portfolio_db
APP_ENV=development
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
SESSION_TTL_HOURS=24
SESSION_COOKIE_NAME=portfolio_session
SESSION_COOKIE_SECURE=false
EMAIL_VERIFICATION_REQUIRED=false
EMAIL_VERIFICATION_TOKEN_TTL_HOURS=24
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
APP_PUBLIC_URL=http://localhost:3000
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
DB_POOL_MIN=1
DB_POOL_MAX=10
AUTH_RATE_LIMIT=30
ADMIN_RATE_LIMIT=20
RATE_LIMIT_WINDOW_SECONDS=60
MARKET_DATA_CACHE_TTL_SECONDS=60

# Backup retention policy
RETENTION_DAYS=30

# Docker Compose database configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me
POSTGRES_DB=portfolio_db

MARKET_DATA_DB_USER=postgres
MARKET_DATA_DB_PASSWORD=change_me
MARKET_DATA_DB_NAME=market_data

# Backend container DATABASE_URL example:
# DATABASE_URL=postgresql://postgres:change_me@postgres:5432/portfolio_db

# Frontend build-time API base for production build
REACT_APP_API_URL=/api

# Production reverse proxy (Caddy)
DOMAIN=your-domain.com
